@{
    Layout = "_ColumnsOne";
    var azureKey = (string)ViewBag.AzureMapsKey;
    var hasAzure = !string.IsNullOrWhiteSpace(azureKey);
    var zoom = (int)ViewBag.DefaultZoom;
    var lat = (decimal)ViewBag.DefaultLat;
    var lng = (decimal)ViewBag.DefaultLng;
}

@section head {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
    <link rel="stylesheet" href="~/Plugins/Widgets.MarketLocator/css/market-map.css" />
}

<div class="market-locator-page">

    <div class="market-hero">
        <div class="market-hero__label">📍 Market Locations</div>
        <h1 class="market-hero__title">Find Us at a Market Near You</h1>
        <p class="market-hero__sub">
            We're out in the community every week. Come taste before you buy and bring the family.
        </p>
    </div>

    <div class="market-filters" id="market-filters">
        <span class="market-filters__label">Show:</span>
        <button class="mf-btn active" data-filter="all">All Markets</button>
        <button class="mf-btn" data-filter="this-week">This Week</button>
        <button class="mf-btn" data-filter="monthly">Monthly</button>
        <div class="market-filters__spacer"></div>
        <a href="/market-locations/ics" class="mf-subscribe" title="Subscribe in Google Calendar, Apple Calendar, Outlook…">
            📅 Subscribe to all dates
        </a>
        <div class="market-view-toggle">
            <button class="mv-btn active" id="btn-map">🗺 Map</button>
            <button class="mv-btn" id="btn-list">☰ List</button>
        </div>
    </div>

    <div class="market-layout" id="market-layout">
        <div class="market-sidebar" id="market-sidebar">
            <div class="market-sidebar__header">
                <strong>Upcoming Markets</strong>
                <span id="market-count">Loading…</span>
            </div>
            <div id="market-card-list"></div>
        </div>
        <div id="market-map"></div>
    </div>

</div>

@section scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    @if (hasAzure)
    {
        <script src="https://atlas.microsoft.com/sdk/javascript/mapcontrol/2/atlas.min.js"></script>
    }
    <script>
        window.MarketLocatorConfig = {
            dataUrl: '/market-locations/data',
            useAzure: @(hasAzure ? "true" : "false"),
            azureKey: '@azureKey',
            defaultLat: @lat,
            defaultLng: @lng,
            defaultZoom: @zoom
        };
    </script>
    <script src="~/Plugins/Widgets.MarketLocator/js/market-map.js"></script>
}
