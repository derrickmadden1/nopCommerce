@{
    Layout = "_ColumnsOne";
    var azureKey = (string)ViewBag.AzureMapsKey;
    var hasAzure = !string.IsNullOrWhiteSpace(azureKey);
    var zoom = (int)ViewBag.DefaultZoom;
    var lat = (decimal)ViewBag.DefaultLat;
    var lng = (decimal)ViewBag.DefaultLng;

    if (ViewBag.SelectedMarket != null)
    {
        var market = (Nop.Plugin.Widgets.MarketLocator.Domain.MarketLocation)ViewBag.SelectedMarket;
        NopHtml.AddTitleParts(market.Name);
        var descriptionText = $"📍 {market.Address}. Join us at the {market.Name}! Dates: {market.UpcomingDates} · Hours: {market.Hours}";
        NopHtml.AddMetaDescriptionParts(descriptionText);

        var ogUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}{Context.Request.QueryString}";
        NopHtml.AddHeadCustomParts($"<meta property=\"og:title\" content=\"{System.Net.WebUtility.HtmlEncode(market.Name)}\" />");
        NopHtml.AddHeadCustomParts($"<meta property=\"og:description\" content=\"{System.Net.WebUtility.HtmlEncode(descriptionText)}\" />");
        NopHtml.AddHeadCustomParts($"<meta property=\"og:url\" content=\"{System.Net.WebUtility.HtmlEncode(ogUrl)}\" />");
        NopHtml.AddHeadCustomParts("<meta property=\"og:type\" content=\"website\" />");

        if (hasAzure)
        {
            var latStr = market.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
            var lngStr = market.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
            var staticMapUrl = $"https://atlas.microsoft.com/map/static/png?api-version=1.0&layer=basic&style=main&zoom=15&center={lngStr},{latStr}&width=1200&height=630&pins=default||{lngStr}%20{latStr}&subscription-key={azureKey}";

            NopHtml.AddHeadCustomParts($"<meta property=\"og:image\" content=\"{System.Net.WebUtility.HtmlEncode(staticMapUrl)}\" />");
            NopHtml.AddHeadCustomParts("<meta property=\"og:image:width\" content=\"1200\" />");
            NopHtml.AddHeadCustomParts("<meta property=\"og:image:height\" content=\"630\" />");
            NopHtml.AddHeadCustomParts("<meta name=\"twitter:card\" content=\"summary_large_image\" />");
        }
    }

    NopHtml.AddHeadCustomParts("<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css\" />");
    NopHtml.AddHeadCustomParts("<link rel=\"stylesheet\" href=\"/Plugins/Widgets.MarketLocator/wwwroot/css/market-map.css\" />");

    NopHtml.AppendScriptParts(ResourceLocation.Footer, "https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js");
    if (hasAzure)
    {
        NopHtml.AppendScriptParts(ResourceLocation.Footer, "https://atlas.microsoft.com/sdk/javascript/mapcontrol/2/atlas.min.js");
    }

    var selectedIdValue = ViewBag.SelectedId != null ? ViewBag.SelectedId.ToString() : "null";
    var useAzure = hasAzure ? "true" : "false";
    var inlineConfig = $@"
        <script>
        window.MarketLocatorConfig = {{
            dataUrl: '/market-locations/data',
            useAzure: {useAzure},
            azureKey: '{azureKey}',
            defaultLat: {lat.ToString(System.Globalization.CultureInfo.InvariantCulture)},
            defaultLng: {lng.ToString(System.Globalization.CultureInfo.InvariantCulture)},
            defaultZoom: {zoom},
            selectedId: {selectedIdValue}
        }};
        console.log('MarketLocator: Config injected.');
        document.getElementById('market-count').textContent = 'Config injected, waiting for script...';
        </script>
    ";
    NopHtml.AddInlineScriptParts(ResourceLocation.Footer, inlineConfig);
    NopHtml.AddScriptParts(ResourceLocation.Footer, "~/Plugins/Widgets.MarketLocator/wwwroot/js/market-map.js", excludeFromBundle: true);
}

<div class="page market-locator-page">

    <div class="market-hero">
        <div class="market-hero__label">📍 Market Locations</div>
        <h1 class="market-hero__title">Find Us at a Market Near You</h1>
        <p class="market-hero__sub">
            We're out in the community most weeks. Come and see us, discover the fragrances before you buy and bring the family.
        </p>
    </div>

    <div class="market-filters" id="market-filters">
        <span class="market-filters__label">Show:</span>
        <button class="mf-btn active" data-filter="all">All Markets</button>
        <button class="mf-btn" data-filter="this-week">This Week</button>
        <button class="mf-btn" data-filter="monthly">Monthly</button>
        <div class="market-filters__spacer"></div>
        <a href="/market-locations/ics" class="mf-subscribe" title="Subscribe in Google Calendar, Apple Calendar, Outlook…">
            📅 Subscribe to all dates
        </a>
        <div class="market-view-toggle">
            <button class="mv-btn active" id="btn-map">🗺 Map</button>
            <button class="mv-btn" id="btn-list">☰ List</button>
        </div>
    </div>

    <div class="market-layout" id="market-layout">
        <div class="market-sidebar" id="market-sidebar">
            <div class="market-sidebar__header">
                <strong>Upcoming Markets</strong>
                <span id="market-count">Loading…</span>
            </div>
            <div id="market-card-list"></div>
        </div>
        <div id="market-map"></div>
    </div>

</div>
