@model Nop.Plugin.Widgets.MarketLocator.Models.MarketLocatorSettingsModel
@{
    Layout = "_AdminLayout";
    ViewBag.Title = "Market Locator — Settings";
}

<div class="content-header clearfix">
    <h1 class="float-left">Market Locator Settings</h1>
    <div class="float-right">
        <a asp-action="List" class="btn btn-info">
            <i class="fas fa-map-marker-alt"></i> Manage Locations
        </a>
    </div>
</div>

<div class="content">
    <div class="card card-default">
        <div class="card-body">
            <form asp-action="Configure" method="post">
                <div asp-validation-summary="All" class="alert alert-danger"></div>

                <div class="form-group row">
                    <div class="col-md-3">
                        <nop-label asp-for="AzureMapsKey" />
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="AzureMapsKey" />
                        <span class="hint">
                            Leave blank to use free CartoDB tiles (no key required).
                            Add your Azure Maps key to switch to Azure Maps tiles and unlock geocoding.
                        </span>
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-md-3"><nop-label asp-for="DefaultLatitude" /></div>
                    <div class="col-md-9"><nop-editor asp-for="DefaultLatitude" /></div>
                </div>

                <div class="form-group row">
                    <div class="col-md-3"><nop-label asp-for="DefaultLongitude" /></div>
                    <div class="col-md-9"><nop-editor asp-for="DefaultLongitude" /></div>
                </div>

                <div class="form-group row">
                    <div class="col-md-3"><nop-label asp-for="DefaultZoom" /></div>
                    <div class="col-md-9">
                        <nop-editor asp-for="DefaultZoom" />
                        <span class="hint">Recommended: 10–12 for a city view.</span>
                    </div>
                </div>

                <hr />

                <div class="form-group row">
                    <div class="col-md-3"><nop-label asp-for="ShowTeaserWidget" /></div>
                    <div class="col-md-9"><nop-editor asp-for="ShowTeaserWidget" /></div>
                </div>

                <div class="form-group row">
                    <div class="col-md-3"><nop-label asp-for="TeaserMaxItems" /></div>
                    <div class="col-md-9"><nop-editor asp-for="TeaserMaxItems" /></div>
                </div>

                <div class="form-group row">
                    <div class="col-md-9 offset-md-3">
                        <button type="submit" class="btn btn-primary">Save Settings</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
