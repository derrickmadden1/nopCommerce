@model Nop.Plugin.Widgets.SeoEnhancements.Models.FaqGenerateReviewModel

@{
    Layout = "_AdminLayout";
    ViewBag.Title = "Review Generated FAQs";
    NopHtml.SetActiveMenuItemSystemName("Widgets.SeoEnhancements");
}

<div class="content-header clearfix">
    <h1 class="float-left">Review Generated FAQs — @Model.EntityName</h1>
    <div class="float-right">
        <a href="@Url.Action("Configure")" class="btn btn-info">
            <i class="fas fa-arrow-left"></i>
            Back to list
        </a>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card card-default">
            <div class="card-body">
                <p class="text-muted">
                    Generated by Azure OpenAI from the product/category description. Review each pair —
                    uncheck or edit anything before saving. Only checked items will be created.
                </p>

                <form asp-controller="SeoEnhancements" asp-action="SaveGenerated" method="post">
                    <input asp-for="EntityTypeId" type="hidden" />
                    <input asp-for="EntityId" type="hidden" />
                    <input asp-for="EntityName" type="hidden" />

                    @for (var i = 0; i < Model.Candidates.Count; i++)
                    {
                        <div class="card mb-3" style="border-left: 4px solid #4a7c59;">
                            <div class="card-body">
                                <input asp-for="Candidates[i].Include" type="hidden" value="false" />
                                <div class="form-check mb-2">
                                    <input asp-for="Candidates[i].Include" class="form-check-input" type="checkbox" value="true" checked="@Model.Candidates[i].Include" />
                                    <label class="form-check-label font-weight-bold">Include this FAQ</label>
                                </div>

                                <div class="form-group">
                                    <label>Question</label>
                                    <input asp-for="Candidates[i].Question" class="form-control" />
                                </div>

                                <div class="form-group mb-0">
                                    <label>Answer</label>
                                    <textarea asp-for="Candidates[i].Answer" class="form-control" rows="2"></textarea>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="form-group">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Save Checked FAQs
                        </button>
                        <a href="@Url.Action("Configure")" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
