@model IList<Nop.Plugin.Widgets.SeoEnhancements.Domain.SeoFaqItem>
@* FAQ accordion rendered on product/category pages.
   Pairs with FAQPage JSON-LD injected via SeoSchema component. *@

<div class="seo-faq-block" itemscope itemtype="https://schema.org/FAQPage">
    <h2 class="seo-faq-heading">Frequently Asked Questions</h2>
    <div class="seo-faq-list">
        @foreach (var item in Model)
        {
            <div class="seo-faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
                <button class="seo-faq-question"
                        type="button"
                        aria-expanded="false"
                        itemprop="name">
                    @item.Question
                    <span class="seo-faq-icon" aria-hidden="true">+</span>
                </button>
                <div class="seo-faq-answer" hidden
                     itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                    <div itemprop="text">
                        @Html.Raw(item.Answer)
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .seo-faq-block {
        margin: 2rem 0;
        border-top: 1px solid #e0e0e0;
    }

    .seo-faq-heading {
        font-size: 1.25rem;
        margin-bottom: 1rem;
        color: #333;
    }

    .seo-faq-item {
        border-bottom: 1px solid #e0e0e0;
    }

    .seo-faq-question {
        width: 100%;
        background: none;
        border: none;
        padding: 1rem 0;
        text-align: left;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: #222;
        transition: color 0.2s;
    }

        .seo-faq-question:hover {
            color: #4a7c59; /* adjust to your theme colour */
        }

        .seo-faq-question[aria-expanded="true"] .seo-faq-icon {
            transform: rotate(45deg);
        }

    .seo-faq-icon {
        font-size: 1.4rem;
        line-height: 1;
        transition: transform 0.2s;
        flex-shrink: 0;
        margin-left: 1rem;
    }

    .seo-faq-answer {
        padding: 0 0 1rem 0;
        color: #555;
        line-height: 1.6;
    }
</style>

<script>
    (function () {
        document.querySelectorAll('.seo-faq-question').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var expanded = this.getAttribute('aria-expanded') === 'true';
                var answer = this.nextElementSibling;
                this.setAttribute('aria-expanded', String(!expanded));
                if (expanded) {
                    answer.hidden = true;
                } else {
                    answer.hidden = false;
                }
            });
        });
    })();
</script>
