@model Nop.Plugin.Widgets.AiRecommendations.Models.RecommendationModel

@if (Model.Products.Any())
{
    <div class="ai-recommendations personalised">
        <h3 class="recommendations-title">@Model.Title</h3>
        <div class="recommendations-grid">
            @foreach (var product in Model.Products)
            {
                <div class="recommendation-item">
                    <a href="@Url.RouteUrl("Product", new { SeName = product.SeName })">
                        <div class="recommendation-picture">
                            <img src="@product.PictureUrl" alt="@product.Name" loading="lazy" />
                        </div>
                        <div class="recommendation-info">
                            <div class="recommendation-name">@product.Name</div>
                            <div class="recommendation-price">@product.Price</div>
                        </div>
                    </a>
                    <div class="recommendation-actions product-actions" style="margin-top: 10px; text-align: center;">
                        <div class="buttons" style="display: flex; justify-content: center; width: 100%;">
                            @{
                                var addtocartlink = Url.RouteUrl("AddProductToCart-Catalog", new { productId = product.Id, shoppingCartTypeId = 1, quantity = 1 });
                            }
                            <button type="button" class="button-2 product-box-add-to-cart-button" onclick="AjaxCart.addproducttocart_catalog('@addtocartlink');return false;" style="width: 100%;">Add to cart</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
