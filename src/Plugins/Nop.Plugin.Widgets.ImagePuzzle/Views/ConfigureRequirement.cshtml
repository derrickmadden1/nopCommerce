@{
    Layout = "";
}
@model Nop.Plugin.Widgets.ImagePuzzle.Models.RequirementModel

    <script>
    $(function() {
        $('#save-puzzle-requirement-@Model.RequirementId').click(function () {
            var discountId = @Model.DiscountId;
            var requirementId = @Model.RequirementId;

            var postData = {
                DiscountId: discountId,
                RequirementId: requirementId
            };
            addAntiForgeryToken(postData);

            $.ajax({
                cache: false,
                type: "POST",
                url: "@(Url.Action("ConfigureRequirement", "Puzzle", new { area = "Admin" }))",
                data: postData,
                success: function (data, textStatus, jqXHR) {
                    if (data.NewRequirementId) {
                        $('#pnl-save-requirement-result@(Model.RequirementId)').fadeIn("slow").delay(1000).fadeOut("slow");
                        //notify parent if it's a new requirement
                        @if (Model.RequirementId == 0)
                        {
                            <text>$("#discountRequirementContainer").trigger('nopnewdiscountruleadded', [data.NewRequirementId]);</text>
                        }
                    } else if (data.Errors) {
                        alert(data.Errors[0]);
                    }
                },
                error: function (jqXHR, textStatus, errorThrown) {
                    alert('Error saving requirement');
                }
            });
        });
    });
    </script>

<div class="form-group row">
    <div class="col-md-3 requirement-label-col">
        <label class="col-form-label">
            Puzzle Requirement
        </label>
    </div>
    <div class="col-md-9 requirement-data-col">
        <div class="requirement-data-input">
            Customers must solve the interactive product image puzzle to qualify for this discount. No further configuration is required.
        </div>
        <div class="requirement-data-buttons">
            <button type="button" id="save-puzzle-requirement-@Model.RequirementId" class="btn btn-primary">Save</button>
        </div>
    </div>
</div>
<div class="form-group row">
    <div class="offset-md-3 col-md-9 requirement-messages-col">
        <div id="pnl-save-requirement-result@(Model.RequirementId)" style="display: none;" class="text-green margin-t-5">
            Saved successfully.
        </div>
    </div>
</div>
