@model RegisterModel
@{
    Layout = "_ColumnsOne";

    //title
    NopHtml.AddTitleParts(T("PageTitle.Register").Text);
    //page class
    NopHtml.AppendPageCssClassParts("html-registration-page");
}

<div class="page registration-page section-container">
    <div class="section-header">
        <h1>@T("Account.Register")</h1>
    </div>

    <div class="page-body">
        @await Component.InvokeAsync("Widget", new { widgetZone = PublicWidgetZones.RegisterTop, additionalData = Model })
        
        <div class="registration-wrapper-modern">
            <form asp-route="@NopRouteNames.Standard.REGISTER" asp-route-returnurl="@Context.Request.Query["ReturnUrl"]" method="post" autocomplete="off" class="registration-form-modern">
                <div asp-validation-summary="ModelOnly" class="message-error"></div>
                
                <section class="fieldset-modern">
                    <div class="fieldset-title">
                        <h2>@T("Account.YourPersonalDetails")</h2>
                    </div>
                    <div class="form-fields-modern">
                        @if (Model.GenderEnabled)
                        {
                            <div class="form-group-modern gender-modern">
                                <label>@T("Account.Fields.Gender")</label>
                                <div class="gender-options-modern">
                                    <label class="gender-option">
                                        <input type="radio" asp-for="Gender" value="M" checked="@(Model.Gender == "M")" />
                                        <span>@T("Account.Fields.Gender.Male")</span>
                                    </label>
                                    <label class="gender-option">
                                        <input type="radio" asp-for="Gender" value="F" checked="@(Model.Gender == "F")" />
                                        <span>@T("Account.Fields.Gender.Female")</span>
                                    </label>
                                </div>
                            </div>
                        }
                        
                        <div class="form-row-modern">
                            @if (Model.FirstNameEnabled)
                            {
                                <div class="form-group-modern">
                                    <label asp-for="FirstName"></label>
                                    <input asp-for="FirstName" class="form-control" />
                                    <span asp-validation-for="FirstName"></span>
                                </div>
                            }
                            @if (Model.LastNameEnabled)
                            {
                                <div class="form-group-modern">
                                    <label asp-for="LastName"></label>
                                    <input asp-for="LastName" class="form-control" />
                                    <span asp-validation-for="LastName"></span>
                                </div>
                            }
                        </div>

                        @if (Model.DateOfBirthEnabled)
                        {
                            <div class="form-group-modern dob-modern">
                                <label>@T("Account.Fields.DateOfBirth")</label>
                                <div class="dob-selectors-modern">
                                    <nop-date-picker asp-day-name="@Html.NameFor(x => x.DateOfBirthDay)"
                                                     asp-month-name="@Html.NameFor(x => x.DateOfBirthMonth)"
                                                     asp-year-name="@Html.NameFor(x => x.DateOfBirthYear)"
                                                     asp-begin-year="@(DateTime.Now.AddYears(-110))"
                                                     asp-end-year="@(DateTime.UtcNow)"
                                                     asp-selected-date="@Model.ParseDateOfBirth()" />
                                </div>
                                <span asp-validation-for="DateOfBirthDay"></span>
                            </div>
                        }

                        <div class="form-group-modern">
                            <label asp-for="Email"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email"></span>
                        </div>

                        @if (Model.UsernamesEnabled)
                        {
                            <div class="form-group-modern">
                                <label asp-for="Username"></label>
                                <input asp-for="Username" class="form-control" />
                                <span asp-validation-for="Username"></span>
                                @if (Model.CheckUsernameAvailabilityEnabled)
                                {
                                    @await Html.PartialAsync("_CheckUsernameAvailability")
                                }
                            </div>
                        }
                    </div>
                </section>

                <section class="fieldset-modern">
                    <div class="fieldset-title">
                        <h2>@T("Account.YourPassword")</h2>
                    </div>
                    <div class="form-fields-modern">
                        <div class="form-row-modern">
                            <div class="form-group-modern">
                                <label asp-for="Password"></label>
                                <input asp-for="Password" class="form-control" />
                                <span asp-validation-for="Password"></span>
                            </div>
                            <div class="form-group-modern">
                                <label asp-for="ConfirmPassword"></label>
                                <input asp-for="ConfirmPassword" class="form-control" />
                                <span asp-validation-for="ConfirmPassword"></span>
                            </div>
                        </div>
                    </div>
                </section>

                @if (Model.NewsletterEnabled)
                {
                    <section class="fieldset-modern options-section-modern">
                        <div class="form-fields-modern checkbox-list-modern">
                            @for (int i = 0; i < Model.NewsLetterSubscriptions.Count; i++)
                            {
                                <div class="checkbox-item-modern">
                                    <input type="hidden" asp-for="NewsLetterSubscriptions[i].TypeId" />
                                    <input type="checkbox" asp-for="NewsLetterSubscriptions[i].IsActive" id="newsletter_@i" />
                                    <label for="newsletter_@i">@T("Account.SubscribeToNewsletter") (@Model.NewsLetterSubscriptions[i].Name)</label>
                                </div>
                            }
                        </div>
                    </section>
                }

                @if (Model.AcceptPrivacyPolicyEnabled)
                {
                    <section class="fieldset-modern consent-section-modern">
                        <div class="checkbox-item-modern">
                            <input id="accept-consent" type="checkbox" name="accept-consent" />
                            <label for="accept-consent">
                                @T("Account.Fields.AcceptPrivacyPolicy")
                                <a class="read" id="read-privacyinfo" href="@await NopUrl.RouteTopicUrlAsync("privacyinfo")">@T("Account.Fields.AcceptPrivacyPolicy.Read")</a>
                            </label>
                        </div>
                    </section>
                }

                <div class="registration-footer-modern">
                    <button type="submit" name="register-button" id="register-button" class="btn-primary register-btn-modern">@T("Account.Register.Button")</button>
                </div>
            </form>

            <div class="external-auth-wrapper-modern">
                @await Component.InvokeAsync("ExternalMethods", "ExternalAuthentication")
            </div>
        </div>

        @await Component.InvokeAsync("Widget", new { widgetZone = PublicWidgetZones.RegisterBottom, additionalData = Model })
    </div>
</div>
