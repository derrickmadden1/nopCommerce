@inherits Nop.Web.Framework.Mvc.Razor.NopRazorPage<TModel>
@using Nop.Web.Components
@using Nop.Web.Framework.Infrastructure
@using Nop.Web.Framework.UI

<header class="header-modern">

    <!-- Utility Bar (Dark) -->
    <div class="header-utility">
        <div class="utility-container">
            <div class="utility-social">
                <!-- Social links would go here -->
                <span class="social-placeholder">Follow Us</span>
            </div>
            <div class="utility-center">
                <span>*** Free UK Shipping On All Orders Over £40 ***</span>
            </div>
            <div class="utility-actions">
                @await Component.InvokeAsync("CurrencySelector")
                @await Component.InvokeAsync("LanguageSelector")
                @await Component.InvokeAsync("HeaderLinks")
            </div>
        </div>
    </div>

    <!-- Main Header Area -->
    <div class="header-main-area">
        <!-- Logo Row -->
        <div class="header-logo-row">
            <div class="header-logo">
                @await Component.InvokeAsync(typeof(LogoViewComponent))
            </div>
            <div class="header-search-cart">
                <div class="search-box">
                    @await Component.InvokeAsync(typeof(SearchBoxViewComponent))
                </div>
                <a href="javascript:void(0)" id="cart-toggle" class="cart-link">
                    @T("ShoppingCart")
                </a>
            </div>
        </div>

        <!-- Navigation Row -->
        <nav class="main-nav-row">
            @inject Nop.Services.Plugins.IPluginService pluginService

            @{
                var descriptor = pluginService
                .GetPluginDescriptorBySystemNameAsync<Nop.Services.Plugins.IPlugin>("Misc.MegaMenu")
                .Result;

                var megaMenuInstalled = descriptor != null;
            }

            @if (megaMenuInstalled)
            {
                @await Component.InvokeAsync("MegaMenu")
            }
        </nav>
    </div>

    <!-- Slide‑in mini cart -->
    <div id="mini-cart-panel" class="mini-cart-panel">
        <div class="mini-cart-header" style="display:flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <h3 style="margin:0;">Your Cart</h3>
            <a href="javascript:void(0)" id="cart-close" style="color: var(--dark-charcoal); text-decoration: none; font-size: 1.5rem;">&times;</a>
        </div>
        @await Component.InvokeAsync(typeof(OrderSummaryViewComponent))
    </div>

</header>

<script>
    document.getElementById("cart-toggle").addEventListener("click", function () {
        document.getElementById("mini-cart-panel").classList.add("open");
    });
    document.getElementById("cart-close").addEventListener("click", function () {
        document.getElementById("mini-cart-panel").classList.remove("open");
    });

    // Sticky header transition
    window.addEventListener("scroll", function() {
        const header = document.querySelector(".header-modern");
        if (window.scrollY > 100) {
            header.classList.add("sticky-shrink");
        } else {
            header.classList.remove("sticky-shrink");
        }
    });
</script>
