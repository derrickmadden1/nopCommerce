@using Nop.Web.Models.Catalog
@model ProductOverviewModel

<div class="product-card">
    <a href="@Model.SeName" class="product-image-wrapper">
        @{var pictureModel = Model.PictureModels.FirstOrDefault();}
        <img class="product-image" src="@pictureModel.ImageUrl" alt="@pictureModel.AlternateText" />
        @await Component.InvokeAsync(typeof(WidgetViewComponent), new { widgetZone = PublicWidgetZones.ProductBoxAddinfoMiddle, additionalData = Model })
    </a>

    <div class="product-info">
        <h3 class="product-title">
            <a href="@Model.SeName">@Model.Name</a>
        </h3>

        <div class="product-price">
            @Html.Raw(Model.ProductPrice.Price)
        </div>

        <div class="product-actions">
            @await Html.PartialAsync("_ProductBoxAddToCart", Model)
        </div>
    </div>
</div>