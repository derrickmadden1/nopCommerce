@inherits Nop.Web.Framework.Mvc.Razor.NopRazorPage<TModel>

@{
    Layout = "_ColumnsOne";
}

@await Component.InvokeAsync("Widget", new { widgetZone = "homepage_top" })

<!-- HERO SECTION -->
<section class="hero">
    <div class="hero-inner">
        <h1>Live Inspired</h1>
        <p>Crafted essentials for a life well lived</p>
        <a href="/new-products" class="btn-primary-outline">Explore the Collection</a>
    </div>
</section>

<!-- BRAND STORY BLOCK -->
<section class="brand-story">
    <div class="story-inner">
        <h2>Our Philosophy</h2>
        <p>We believe in thoughtful design, sustainable materials, and products that elevate everyday living.</p>
        <a href="/about-us" class="link-more">Discover Our Story</a>
    </div>
</section>

<!-- FEATURED COLLECTION -->
<section class="featured-collection section-container">
    <div class="section-header">
        <h2>Featured Collection</h2>
    </div>
    <div class="product-grid">
        @await Component.InvokeAsync("Widget", new { widgetZone = "homepage_featured_collection" })
    </div>
</section>

<!-- LIFESTYLE IMAGE STRIP -->
<section class="lifestyle-strip">
    <div class="strip-image img1"></div>
    <div class="strip-image img2"></div>
    <div class="strip-image img3"></div>
</section>

<!-- HOMEPAGE TEXT TOPIC -->
@await Component.InvokeAsync("TopicBlock", new { systemName = "HomepageText" })

@await Component.InvokeAsync("Widget", new { widgetZone = "homepage_bottom" })