@model ProductModel

@{
    var allowedMimeTypes = new List<string> { MimeTypes.ModelGlb };
    var random = CommonHelper.GenerateRandomInteger();
    var clientId = $"picture{random}";
    var elementId = $"{clientId}element";
    var files = new List<object>();

    if (Model?.Product3dObject?.Id > 0)
    {
        var fileName = $"{Model.Product3dObject.FileName}";
        files.Add(
            new
            {
                source = fileName,
                options = new
                {
                    type = "local",
                    file = new
                    {
                        name = fileName,
                        type = MimeTypes.ModelGlb,
                        size = Model.Product3dObject.FileSize
                    },
                    metadata = new
                    {
                        url = Model.Product3dObject.FileUrl
                    }
                }
            });
    }
}

<input asp-for="Product3dObject.Id" type="hidden" />
<div class="card card-default">
    <div class="card-body">
        <div class="form-group row">
            <div class="col-md-3">
                <nop-label asp-for="Product3dObject.FileName" />
            </div>
            <div class="col-md-9">
                <div id="@elementId" class="filepond"></div>
            </div>
        </div>
        <div id="additional-inf">
            <div class="form-group row">
                <div class="col-md-3">
                    <nop-label asp-for="Product3dObject.AltAttribute" />
                </div>
                <div class="col-md-9">
                    <nop-editor asp-for="Product3dObject.AltAttribute" />
                    <span asp-validation-for="Product3dObject.AltAttribute"></span>
                </div>
            </div>
            <div class="form-group row">
                <div class="col-md-3">
                    <nop-label asp-for="Product3dObject.PreviewPictureId" />
                </div>
                <div class="col-md-9">
                    <nop-editor asp-for="Product3dObject.PreviewPictureId" />
                    <span asp-validation-for="Product3dObject.PreviewPictureId"></span>
                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="col-md-9 offset-md-3">
                <button type="button" class="btn btn-primary" id="save3dObjectButton">@T("Admin.Catalog.Products.Multimedia.Object3d.Save")</button>
            </div>
        </div>
    </div>
</div>

@* register CSS and JS *@
<link rel="stylesheet" href="~/lib_npm/filepond/filepond.min.css" />
<script asp-exclude-from-bundle="true" src="~/lib_npm/filepond/filepond.min.js" asp-location="Footer"></script>
<script asp-exclude-from-bundle="true" src="~/lib_npm/filepond-plugin-file-validate-type/filepond-plugin-file-validate-type.min.js" asp-location="Footer"></script>
<script asp-exclude-from-bundle="true" src="~/lib_npm/filepond-plugin-file-validate-size/filepond-plugin-file-validate-size.min.js" asp-location="Footer"></script>

<script asp-location="Footer">
    $(async function () {

        // Register the plugins
        FilePond.registerPlugin(FilePondPluginFileValidateType, FilePondPluginFileValidateSize);
        const allowedExtensions = @Html.Raw(Json.Serialize(allowedMimeTypes));
        
        const productId = $('#@Html.IdFor(m => m.Id)').val();
        const $modelEl = $('#@Html.IdFor(m => m.Product3dObject.Id)');
        const $altTextEl = $('#@Html.IdFor(m => m.Product3dObject.AltAttribute)');
        const $removeEl = $('#@clientId');
        const $save3dObjectButtonEl = $('#save3dObjectButton');
        const $3dObjectInfoBlockEl = $("#additional-inf");

        @if (Model.Product3dObject == null || Model.Product3dObject.Id == 0)
        {
            <text>$3dObjectInfoBlockEl.hide();</text>
        }

        function reset3dObjectToDefault() {
            $modelEl.val('0');
            $3dObjectInfoBlockEl.hide();
        }

        const serverConfig = {
            process: (fieldName, file, metadata, load, error, progress, abort, transfer, options) => {
                const formData = new FormData();
                formData.append(fieldName, file, file.name);
                formData.append('productId', productId);

                const request = new XMLHttpRequest();
                request.open('POST', '@Url.Content("~/Admin/Product/Upload3dObject")');

                request.upload.onprogress = (e) => {
                    progress(e.lengthComputable, e.loaded, e.total);
                };

                request.onload = function () {
                    const commonError = '@T("Common.Error")';
                    if (request.status < 200 || request.status >= 300) {
                        error(commonError);
                        return;
                    }

                    const response = JSON.parse(request.responseText);

                    if (response.success) {
                        load(request.responseText);
                        $modelEl.val(response.objectId);
                        $3dObjectInfoBlockEl.show();

                    } else {
                        error(response.message || commonError);
                    }
                };

                request.send(formData);
            },
            remove: (source, load, error) => {
                reset3dObjectToDefault();
                load();
            },
            revert: (uniqueFileId, load, error) => {
                reset3dObjectToDefault();
                load();
            },
        };

        // Create a FilePond instance
        const filePond3dInstance = FilePond.create(document.querySelector('#@elementId'), {
            credits: false,
            allowMultiple: false,
            maxFiles: 1,
            maxFileSize: '@Model.Product3dObject.UploadLimit' + 'MB',
            allowDownloadByUrl: true,
            server: serverConfig,
            labelFileProcessingError: (err) => err.body,
            acceptedFileTypes: allowedExtensions,
            fileValidateTypeDetectType: (source, type) => {
                return new Promise((resolve, reject) => {
                    if (source.name.endsWith('.glb')) {
                        resolve('@MimeTypes.ModelGlb');
                    } else {
                        resolve(type);
                    }
                });
            },
            labelIdle: '@T("Common.FileUploader.DropFiles") / <span class="filepond--label-action">@T("Common.FileUploader.Browse")</span>',
            labelFileProcessing: '@T("Common.FileUploader.Processing")',
            files: @Json.Serialize(files),
        });

        $removeEl.on('click', function (e) {
            reset3dObjectToDefault();
            filePond3dInstance.removeFiles();
            $(this).hide();
        });

        $save3dObjectButtonEl.click(function () {
            $save3dObjectButtonEl.attr('disabled', true);
            var postData = {
                Id: $modelEl.val(),
                PreviewPictureId: $("#@Html.IdFor(model => model.Product3dObject.PreviewPictureId)").val(),
                AltAttribute: $("#@Html.IdFor(model => model.Product3dObject.AltAttribute)").val()
            };
            addAntiForgeryToken(postData);
                    
            $.ajax({
                cache: false,
                type: "POST",
                url: "@Html.Raw(Url.Action("Product3dObjectSave", "Product", new { ProductId = Model.Id }))",
                data: postData,
                success: function (data, textStatus, jqXHR) {
                    if (!data.success) {
                        //display errors if returned
                        display_nop_error(data);
                        return;
                    }
                    
                    if (data.deleted) {
                        $altTextEl.val('');
                        var picFilePond = FilePond.find($(document.getElementById('Product3dObject_PreviewPictureId')).siblings('.filepond')[0]);
                        picFilePond.removeFiles();
                    }
                },
                complete: function (jqXHR, textStatus) {
                    $save3dObjectButtonEl.attr('disabled', false);
                }
            });
        });
    });
</script>
    