@model PriceListModel

@if (Model.Id > 0)
{    
    <div class="card-body">
        @await Html.PartialAsync("Table", new DataTablesModel
        {
            Name = "customers-grid",
            UrlRead = new DataUrl("CustomerList", "PriceList", new RouteValueDictionary { [nameof(Model.PriceListCustomerSearchModel.PriceListId)] = Model.PriceListCustomerSearchModel.PriceListId }),
            UrlDelete = new DataUrl("CustomerDelete", "PriceList", null),
            Length = Model.PriceListCustomerSearchModel.PageSize,
            LengthMenu = Model.PriceListCustomerSearchModel.AvailablePageSizes,
            ColumnCollection = new List<ColumnProperty>
                {
                    new ColumnProperty(nameof(PriceListCustomerModel.CustomerEmail))
                    {
                        Title = T("Admin.Catalog.PriceList.Customers.Fields.Customer").Text
                    },
                    new ColumnProperty(nameof(PriceListCustomerModel.CustomerId))
                    {
                        Title = T("Admin.Common.View").Text,
                        Width = "100",
                        ClassName = NopColumnClassDefaults.Button,
                        Render = new RenderButtonView(new DataUrl("~/Admin/Customer/Edit/", nameof(PriceListCustomerModel.CustomerId)))
                    },
                    new ColumnProperty(nameof(PriceListCustomerModel.Id))
                    {
                        Title = T("Admin.Common.Delete").Text,
                        Width = "100",
                        Render = new RenderButtonRemove(T("Admin.Common.Delete").Text),
                        ClassName = NopColumnClassDefaults.Button
                    }
                }
        })
    </div>
    <div class="card-footer">
        <button type="submit" id="btnAddNewCustomer"
                onclick="javascript:OpenWindow('@(Url.Action("CustomerAddPopup", "PriceList", new { priceListId = Model.Id, btnId = "btnRefreshCustomers", formId = "price-list-form" }))', 800, 800, true); return false;"
                class="btn btn-primary">
            @T("Admin.Catalog.PriceList.Customers.AddNew")
        </button>
        <button type="submit" id="btnRefreshCustomers" style="display: none"></button>
        <script>
            $(function() {
                $('#btnRefreshCustomers').click(function () {
                    //refresh grid
                    updateTable('#customers-grid');

                    //return false to don't reload a page
                    return false;
                });
            });
        </script>
    </div>
}
else
{
    <div class="card-body">
        @T("Admin.Catalog.PriceList.Customers.SaveBeforeEdit")
    </div>
}

